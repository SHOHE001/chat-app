+### src/db.js — getThreadMessages / getMessageById（新設スニペット）
+
+```js
+export function getThreadMessages(db, rootId, limit = 50) {
+  const rows = db
+    .prepare(
+      `SELECT * FROM (
+         SELECT id, room_id, author, body, created_at, thread_root_id
+         FROM messages
+         WHERE thread_root_id = ?
+         ORDER BY id DESC
+         LIMIT ?
+       )
+       ORDER BY id ASC`,
+    )
+    .all(rootId, limit);
+  return rows.map((row) => ({
+    id: Number(row.id),
+    room_id: Number(row.room_id),
+    author: row.author,
+    body: row.body,
+    created_at: Number(row.created_at),
+    thread_root_id: Number(row.thread_root_id),
+  }));
+}
+
+export function getMessageById(db, messageId) {
+  const row = db
+    .prepare('SELECT id, room_id, author, body, created_at, thread_root_id FROM messages WHERE id = ?')
+    .get(messageId);
+  if (!row) return undefined;
+  return {
+    id: Number(row.id),
+    room_id: Number(row.room_id),
+    author: row.author,
+    body: row.body,
+    created_at: Number(row.created_at),
+    thread_root_id: row.thread_root_id === null ? null : Number(row.thread_root_id),
+  };
+}
+```
+
+### src/server.js — validateThreadRoot（新設スニペット）
+
+```js
+/**
+ * threadRootId / rootId 入力を検証する。正整数（parseRoomId と同型）→ メッセージ存在
+ * → クライアントの現在ルームに属する → root 自体がスレッド返信でない、をすべて満たせば
+ * root の id を返す。どれか欠ければ null（呼び出し側で thread_not_found に変換）。
+ */
+function validateThreadRoot(db, roomId, value) {
+  const rootId = parseRoomId(value);
+  if (rootId === null) return null;
+  const root = getMessageById(db, rootId);
+  if (!root) return null;
+  if (root.room_id !== roomId) return null;
+  if (root.thread_root_id !== null) return null;
+  return rootId;
+}
+```
