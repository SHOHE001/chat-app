# chat-app 設定サンプル。cp .env.example .env して値を編集する。
# systemd公開運用では /etc/chat-app/chat-app.env に置き、root:chat-app 0640 にする。
# Basic認証・アプリログインの失敗回数制限はコード内既定値を使い、サービス再起動でリセットされる。
# HTTP/WebSocket ポート
PORT=3000
# bind アドレス。未設定なら全 interface（IPv6 :: + IPv4 dual-stack）で待受。
# IPv4 のみに絞るなら 0.0.0.0、ローカルのみなら 127.0.0.1 を指定。
HOST=
# SQLite DB ファイルのパス（相対は起動時 CWD 基準）
DB_PATH=data/chat.db
# サイト入口の Basic 認証。両方設定で有効、両方空で無効。片方のみは起動時エラー。
# BASIC_AUTH_USER にコロン (:) は使用不可。値の前後空白は除去される。
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
# Web Push署名の連絡先URI。mailto: または https:// を指定する。
VAPID_SUBJECT=mailto:you@example.com
# AI巡回（claude -p）。systemdでは絶対パスを推奨。
CLAUDE_BIN=claude
MODERATION_BATCH_SIZE=50
MODERATION_HAIKU_BUDGET_USD=0.10
MODERATION_OPUS_BUDGET_USD=0.75
MODERATION_TIMEOUT_MS=600000
MODERATION_STRIKE_THRESHOLD=3
MODERATION_STRIKE_WINDOW_DAYS=30
MODERATION_MAX_OPUS_CALLS=10
