# chat-app 設定サンプル。cp .env.example .env して値を編集する。
# HTTP/WebSocket ポート
PORT=3000
# bind アドレス。未設定なら全 interface（IPv6 :: + IPv4 dual-stack）で待受。
# IPv4 のみに絞るなら 0.0.0.0、ローカルのみなら 127.0.0.1 を指定。
HOST=
# SQLite DB ファイルのパス（相対は起動時 CWD 基準）
DB_PATH=data/chat.db
# サイト入口の Basic 認証。両方設定で有効、両方空で無効。片方のみは起動時エラー。
# BASIC_AUTH_USER にコロン (:) は使用不可。値の前後空白は除去される。
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
