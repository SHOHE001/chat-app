#!/usr/bin/env bash
set -euo pipefail

zero=0000000000000000000000000000000000000000
allow_rewrite=${GIT_HISTORY_REWRITE_APPROVED:-0}

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "$zero" ]]; then
    if [[ "$allow_rewrite" != "1" ]]; then
      echo "pre-push: ref deletion is blocked: $remote_ref" >&2
      echo "Only after explicit user approval, retry once with GIT_HISTORY_REWRITE_APPROVED=1." >&2
      exit 1
    fi
    continue
  fi

  if [[ "$remote_sha" != "$zero" ]] && ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
    if [[ "$allow_rewrite" != "1" ]]; then
      echo "pre-push: non-fast-forward/history rewrite is blocked: $remote_ref" >&2
      echo "Only after explicit user approval, retry once with GIT_HISTORY_REWRITE_APPROVED=1." >&2
      exit 1
    fi
  fi
done

npm test
